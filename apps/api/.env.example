# Copy to .env — never commit .env
TATUM_API_KEY=
SUI_NETWORK=mainnet
# Shared mainnet: https://sui-mainnet.gateway.tatum.io
# Custom gateway (Tatum dashboard): https://<your-id>.gateway.tatum.io
TATUM_SUI_RPC=https://sui-mainnet.gateway.tatum.io

SUI_PRIVATE_KEY=
SUI_WALLET_ADDRESS=

PACKAGE_ID=
REGISTRY_ID=

SEAL_THRESHOLD=2
# Hackathon demo on mainnet: leave false. Enable post-hackathon with Enoki key servers.
SEAL_ENABLED=false
SEAL_KEY_SERVER_IDS=
# Testnet open servers (see https://seal-docs.wal.app/Pricing#verified-key-servers):
# 0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75,0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8
# Mainnet: request Enoki Seal access — public open servers not listed yet.

WALRUS_AGGREGATOR=https://aggregator.walrus.space/v1
WALRUS_EPOCHS=10
# Optional: dedicated RPC for Walrus writes (defaults to Sui public fullnode)
# WALRUS_SUI_RPC=https://fullnode.mainnet.sui.io:443
PORT=3001
